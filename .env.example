# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Meta WhatsApp Cloud API
META_APP_SECRET=your_meta_app_secret
META_VERIFY_TOKEN=your_meta_webhook_verify_token
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_whatsapp_business_account_id
WHATSAPP_API_VERSION=v18.0
WHATSAPP_TRANSACTION_ALERT_TEMPLATE_NAME=hello_world
WHATSAPP_TRANSACTION_ALERT_TEMPLATE_LANG=en_US

# PawaPay API
PAWAPAY_BASE_URL=https://api.pawapay.io
PAWAPAY_API_KEY=your_pawapay_api_key
PAWAPAY_API_SECRET=your_pawapay_api_secret
PAWAPAY_CORRESPONDENT=MTN_MOMO_COD
PAWAPAY_FLOAT_FALLBACK_USD=1000

# Optional runtime controls
APP_ENV=development
LOG_LEVEL=info
ALLOW_NON_DRC_TEST_NUMBERS=false
AUTO_MARK_PAYMENT_SECURED=false
